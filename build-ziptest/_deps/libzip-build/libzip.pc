prefix=/usr/local
exec_prefix=${prefix}
bindir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

zipcmp=${bindir}/zipcmp

Name: libzip
Description: library for handling zip archives
Version: 1.10.1
Libs:  -L${libdir} -lzip
Libs.private:  -lssl -lcrypto -l$<TARGET_LINKER_FILE:ZLIB::ZLIB>
Cflags: -I${includedir}
