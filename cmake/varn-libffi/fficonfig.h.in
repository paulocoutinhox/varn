/* varn: generated by cmake from libffi expectations (upstream libffi @VARN_LIBFFI_VERSION@). */

#ifndef FFICONFIG_H
#define FFICONFIG_H

#define FFI_CLOSURES 1

#define FFI_MMAP_EXEC_WRIT @VARN_FFI_MMAP_EXEC_WRIT@
#define FFI_EXEC_TRAMPOLINE_TABLE @VARN_FFI_EXEC_TRAMPOLINE_TABLE@
@VARN_FFI_EXEC_STATIC_TRAMP_CPP@

#define PACKAGE "libffi"
#define PACKAGE_BUGREPORT "http://github.com/libffi/libffi/issues"
#define PACKAGE_NAME "libffi"
#define PACKAGE_STRING "libffi @VARN_LIBFFI_VERSION@"
#define PACKAGE_TARNAME "libffi"
#define PACKAGE_URL ""
#define PACKAGE_VERSION "@VARN_LIBFFI_VERSION@"
#define VERSION "@VARN_LIBFFI_VERSION@"

#define SIZEOF_DOUBLE 8
#define STDC_HEADERS 1
#define HAVE_MEMORY_H 1
#define HAVE_STRING_H 1
#define HAVE_STRINGS_H 1
#define HAVE_SYS_TYPES_H 1
#define HAVE_SYS_STAT_H 1
#define HAVE_INTTYPES_H 1
#define HAVE_STDINT_H 1
#define HAVE_STDLIB_H 1
#define HAVE_MEMCPY 1
#define HAVE_MEMMOVE 1
#define HAVE_RAW_API 1

#if defined(_MSC_VER)
# define HAVE_ALLOCA_H 0
# define HAVE_UNISTD_H 0
# define HAVE_HIDDEN_VISIBILITY_ATTRIBUTE 0
# define SIZEOF_SIZE_T @VARN_FFI_SIZEOF_SIZE_T@
# define SIZEOF_LONG_DOUBLE 8
#elif defined(__APPLE__)
# define HAVE_ALLOCA_H 1
# define HAVE_UNISTD_H 1
# define HAVE_HIDDEN_VISIBILITY_ATTRIBUTE 1
# define SIZEOF_SIZE_T @VARN_FFI_SIZEOF_SIZE_T@
# if defined(__aarch64__) || defined(__arm64__)
#  define SIZEOF_LONG_DOUBLE 8
# elif defined(__x86_64__) || defined(__i386__)
#  define SIZEOF_LONG_DOUBLE 16
# else
#  define SIZEOF_LONG_DOUBLE 8
# endif
#elif defined(__ANDROID__)
# define HAVE_ALLOCA_H 1
# define HAVE_UNISTD_H 1
# define HAVE_HIDDEN_VISIBILITY_ATTRIBUTE 1
# define SIZEOF_SIZE_T @VARN_FFI_SIZEOF_SIZE_T@
# define SIZEOF_LONG_DOUBLE 8
#elif defined(__linux__)
# define HAVE_ALLOCA_H 1
# define HAVE_UNISTD_H 1
# define HAVE_HIDDEN_VISIBILITY_ATTRIBUTE 1
# define SIZEOF_SIZE_T @VARN_FFI_SIZEOF_SIZE_T@
# if defined(__aarch64__) || defined(__arm__) || defined(__i386__)
#  define SIZEOF_LONG_DOUBLE 8
# else
#  define SIZEOF_LONG_DOUBLE 16
# endif
#else
# error "varn libffi: unsupported host os (expected Darwin, Linux, Android, or Windows)"
#endif

#if HAVE_HIDDEN_VISIBILITY_ATTRIBUTE
# ifdef LIBFFI_ASM
#  ifdef __APPLE__
#   define FFI_HIDDEN(name) .private_extern name
#  else
#   define FFI_HIDDEN(name) .hidden name
#  endif
# else
#  define FFI_HIDDEN __attribute__((visibility("hidden")))
# endif
#else
# ifdef LIBFFI_ASM
#  define FFI_HIDDEN(name)
# else
#  define FFI_HIDDEN
# endif
#endif

@VARN_FFI_HAVE_AS_X86_PCREL_CPP@
@VARN_FFI_HAVE_AS_X86_64_UNWIND_CPP@
@VARN_FFI_HAVE_AS_CFI_CPP@

#define HAVE_LONG_DOUBLE_VARIANT 0

#endif /* FFICONFIG_H */
